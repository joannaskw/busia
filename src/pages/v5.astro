---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import okladka from '../assets/images/okladka.jpg';
import busiaowal from '../assets/images/busia-owal.png';
import rodzina from '../assets/images/rodzina.png';
import dziecko from '../assets/images/busia-dziecko.png';
import zaleszyczki from '../assets/images/zaleszyczki.png';
import slub from '../assets/images/slub.png';
import stachKawiarnia from '../assets/images/busia-stach-kawiarnia.png';
import teatr from '../assets/images/busia-teatr.png';
import starsza from '../assets/images/busia-starsza.png';
import prawnuczki from '../assets/images/busia-prawnuczki.png';
import autorka from '../assets/images/autorka.jpg';
import testimonials from '../data/testimonials.json';
---
<BaseLayout title="BUSIA — 1911–1996. Historia jednej kobiety" version="v5">

<!-- NAV -->
<nav class="nav">
  <div class="container nav-inner">
    <a href="#" class="nav-logo">BUSIA</a>
    <div class="nav-links">
      <a href="#historia">Historia</a>
      <a href="#autorka">Autorka</a>
      <a href="#zamow" class="btn btn-primary nav-cta">Zamów</a>
    </div>
  </div>
</nav>

<!-- HERO — kontekst epoki -->
<section class="hero">
  <div class="hero-overlay"></div>
  <div class="container hero-inner">
    <div class="hero-text">
      <p class="hero-dates">1911 — 1996</p>
      <h1>BUSIA</h1>
      <p class="hero-subtitle">Historia, która zawojowała Facebook</p>
      <p class="hero-tagline">85 lat. Dwie wojny. Jedna kobieta.</p>
      <p class="hero-desc">Bogusława Lublicka przyszła na świat w zamożnej warszawskiej rodzinie, u progu epoki, która miała zmienić wszystko. Jej historia — opowiedziana przez wnuczkę — to portret pokolenia, które straciło świat i musiało zbudować go od nowa.</p>
      <a href="#zamow" class="btn btn-primary">Zamów książkę</a>
    </div>
    <div class="hero-image">
      <Image src={okladka} alt="Okładka BUSIA" width={380} class="cover-img" />
    </div>
  </div>
</section>

<!-- OŚ CZASU -->
<section id="historia" class="timeline">
  <div class="container">
    <h2>Życie Busi na tle epoki</h2>

    <div class="timeline-line">
      <div class="timeline-entry">
        <div class="tl-year">1911</div>
        <div class="tl-content">
          <div class="tl-context">Warszawa pod zaborem rosyjskim. Dwa lata przed I wojną światową.</div>
          <div class="tl-story">
            <h3>Narodziny</h3>
            <p>Bogusława Lublicka rodzi się w zamożnej rodzinie. Dom przy ul. Brylowskiej, pianino, lekcje tenisa. Świat pełen obietnic.</p>
          </div>
          <div class="tl-photo">
            <Image src={rodzina} alt="Rodzice Busi" width={280} />
          </div>
        </div>
      </div>

      <div class="timeline-entry">
        <div class="tl-year">1918</div>
        <div class="tl-content">
          <div class="tl-context">Polska odzyskuje niepodległość. Początek dwudziestolecia międzywojennego.</div>
          <div class="tl-story">
            <h3>Dzieciństwo w wolnej Polsce</h3>
            <p>Mała Bogusława dorasta w nowej, wolnej Polsce. Warszawa się buduje, rozkwita. Dzieciństwo na ulicach miasta, które właśnie zaczyna oddychać.</p>
          </div>
          <div class="tl-photo">
            <Image src={dziecko} alt="Busia jako dziewczynka" width={250} />
          </div>
        </div>
      </div>

      <div class="timeline-entry">
        <div class="tl-year">1929</div>
        <div class="tl-content">
          <div class="tl-context">Dwudziestolecie międzywojenne. Wielki kryzys na horyzoncie, ale w Polsce jeszcze beztroskość.</div>
          <div class="tl-story">
            <h3>Młodość i Zaleszyczki</h3>
            <p>Wakacje na Kresach, plaża, słońce. Busia jest młoda, piękna, wolna. Przedwojenna Polska w najlepszym wydaniu.</p>
          </div>
          <div class="tl-photo">
            <Image src={zaleszyczki} alt="Busia w Zaleszczykach" width={280} />
          </div>
        </div>
      </div>

      <div class="timeline-entry">
        <div class="tl-year">~1935</div>
        <div class="tl-content">
          <div class="tl-context">Ostatnie spokojne lata przed burzą. Europa zmierza ku wojnie.</div>
          <div class="tl-story">
            <h3>Miłość</h3>
            <p>Stach zdobywa Busię misternie uknutą intrygą w rodzinnej cukierni. Ślub, szczęśliwe małżeństwo, kawiarnie, spacery. Nie wiedzą jeszcze, co przyniosą najbliższe lata.</p>
          </div>
          <div class="tl-photo">
            <Image src={stachKawiarnia} alt="Busia i Stach" width={280} />
            <Image src={slub} alt="Ślub" width={200} />
          </div>
        </div>
      </div>

      <div class="timeline-entry war">
        <div class="tl-year">1939</div>
        <div class="tl-content">
          <div class="tl-context">1 września — atak na Polskę. Początek II wojny światowej.</div>
          <div class="tl-story">
            <h3>Wojna</h3>
            <p>Świat się kończy. Stach działa w AK, zostaje burmistrzem Otwocka. Narodziny syna Jerzyka.</p>
          </div>
        </div>
      </div>

      <div class="timeline-entry war">
        <div class="tl-year">1944</div>
        <div class="tl-content">
          <div class="tl-context">Powstanie Warszawskie. Łapanki, egzekucje. Gruźlica zbiera żniwo.</div>
          <div class="tl-story">
            <h3>Strata</h3>
            <p>Stach umiera na gruźlicę. Ma 38 lat. Busia zostaje sama — 33-letnia kobieta z ośmioletnim synem. Wszystko, co znała, legło w gruzach.</p>
          </div>
        </div>
      </div>

      <div class="timeline-entry">
        <div class="tl-year">1945–70</div>
        <div class="tl-content">
          <div class="tl-context">Polska Ludowa. Nowa rzeczywistość — daleka od przedwojennego dobrobytu.</div>
          <div class="tl-story">
            <h3>Odbudowa</h3>
            <p>Busia nie złamała się. Piekła bułeczki, żeby przeżyć. Budowała kafle w łazience własnymi rękami. Szyła ubrania. Grała w amatorskim teatrze. Nigdy nie narzekała. Była jak jedwabna nić — delikatna, a zarazem mocna.</p>
          </div>
          <div class="tl-photo">
            <Image src={teatr} alt="Busia w teatrze" width={300} />
          </div>
        </div>
      </div>

      <div class="timeline-entry">
        <div class="tl-year">1990–96</div>
        <div class="tl-content">
          <div class="tl-context">Wolna Polska. Busia dożywa końca epoki, z której się wywodziła.</div>
          <div class="tl-story">
            <h3>Babcia</h3>
            <p>Otoczona rodziną — synem, wnuczkami, prawnuczkami. Pachniała, dźwięczała srebrnymi bransoletkami, uczyła robić na drutach i gotować mazurek kajmakowy. Przepis obowiązuje w rodzinie do dziś.</p>
          </div>
          <div class="tl-photo">
            <Image src={prawnuczki} alt="Busia z prawnuczkami" width={350} />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FRAGMENT -->
<section class="excerpt">
  <div class="container">
    <blockquote class="big-quote">
      &bdquo;Zamknij oczy i pomyśl o swojej babci. Co widzisz?&rdquo;
    </blockquote>
    <div class="excerpt-text">
      <p>A teraz opowiem Ci co ja widzę&hellip; Widzę jak wspólnie robimy drożdżowe ciasto, bo ona nie miała już siły, żeby je sama wyrobić, jak zakłada beret, w taki sposób jak tylko ona to robiła&hellip; Nie tylko widzę, ale też słyszę&hellip; Dźwięk kilkunastu srebrnych bransoletek kółeczek&hellip; Mało tego&hellip; Czuję&hellip; Jej zapach i zapach jej rzeczy. Nikt inny tak nie pachniał i nie pachnie.</p>
    </div>
  </div>
</section>

<!-- GŁOSY -->
<section class="testimonials">
  <div class="container">
    <h2>Głosy czytelników</h2>
    <div class="testi-grid">
      {testimonials.slice(0, 6).map((t: { text: string; author: string }) => (
        <div class="testi-card">
          <p>&bdquo;{t.text}&rdquo;</p>
          <cite>— {t.author}</cite>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- AUTORKA -->
<section id="autorka" class="author">
  <div class="container author-inner">
    <Image src={autorka} alt="Bogusława Skwarna" width={350} class="author-img" />
    <div class="author-text">
      <h2>O autorce</h2>
      <div class="author-parallel">
        <div class="parallel-item">
          <span class="parallel-year">1911</span>
          <span>Rodzi się Bogusława Lublicka</span>
        </div>
        <div class="parallel-item">
          <span class="parallel-year">1961</span>
          <span>Rodzi się Bogusława Skwarna — wnuczka. Dokładnie 50 lat później. To samo imię.</span>
        </div>
      </div>
      <p>Więź między nimi była wyjątkowa od pierwszego dnia. BUSIA to pierwsza książka autorki — ale nie pierwsza próba opowiedzenia tej historii. Przez lata zbierała zdjęcia, dokumenty i wspomnienia.</p>
      <p>Książka powstała na prośbę setek czytelników grupy &bdquo;Przedwojenna Polska na fotografii&rdquo; na Facebooku, gdzie autorka publikowała historię w odcinkach.</p>
    </div>
  </div>
</section>

<!-- ZAKUP -->
<section id="zamow" class="product">
  <div class="container">
    <h2>Zamów BUSIĘ</h2>
    <p class="product-sub">85 lat historii. 190 stron. Fotografie, listy, dokumenty, wspomnienia.</p>
    <div class="product-cards">
      <div class="product-card">
        <div class="product-icon">📖</div>
        <h3>Druk</h3>
        <p class="product-details">ok. 190 stron, pełen kolor</p>
        <p class="product-price">99 zł</p>
        <p class="product-shipping">+ koszt wysyłki</p>
        <a href="#" class="btn btn-primary">Zamów</a>
      </div>
      <div class="product-card">
        <div class="product-icon">📱</div>
        <h3>PDF</h3>
        <p class="product-details">Natychmiast po płatności</p>
        <p class="product-price">79 zł</p>
        <p class="product-shipping">Bez wysyłki</p>
        <a href="#" class="btn btn-primary">Zamów</a>
      </div>
    </div>
  </div>
</section>

<!-- STOPKA -->
<footer class="footer">
  <div class="container">
    <p>Kontakt: <a href="mailto:boguslawaskwarna@gmail.com">boguslawaskwarna@gmail.com</a></p>
    <p class="copyright">&copy; 2026 Bogusława Skwarna. Wszelkie prawa zastrzeżone.</p>
  </div>
</footer>

<style>
  /* === V5 PALETTE: Stalowy niebieskoszary ze srebrną patyną === */
  :global(body.v5) {
    --bg: #F3F4F6;
    --bg-alt: #E5E7EB;
    --text: #1F2937;
    --text-light: #6B7280;
    --accent: #374151;
    --accent-light: #78716C;
    --border: #D1D5DB;
    --btn-text: #F3F4F6;
    --war: #991B1B;
  }

  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(243, 244, 246, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
  }

  .nav-inner { display: flex; align-items: center; justify-content: space-between; }
  .nav-logo { font-family: var(--font-heading); font-size: 1.5rem; font-weight: 700; letter-spacing: 0.15em; color: var(--accent); }
  .nav-links { display: flex; align-items: center; gap: 2rem; font-size: 0.9rem; }
  .nav-links a:not(.nav-cta) { color: var(--text-light); }
  .nav-links a:not(.nav-cta):hover { color: var(--accent); }
  .nav-cta { padding: 0.5rem 1.5rem !important; font-size: 0.85rem !important; }

  /* HERO */
  .hero {
    position: relative;
    padding: 8rem 1.5rem 5rem;
    background: var(--accent);
    color: var(--btn-text);
    min-height: 85vh;
    display: flex;
    align-items: center;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: var(--max-width);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-dates {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    letter-spacing: 0.3em;
    opacity: 0.6;
    margin-bottom: 1rem;
  }

  .hero h1 {
    color: #fff;
    margin-bottom: 0.3rem;
    letter-spacing: 0.15em;
  }

  .hero-subtitle {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-style: italic;
    opacity: 0.7;
    margin-bottom: 1rem;
  }

  .hero-tagline {
    font-family: var(--font-heading);
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .hero-desc {
    font-size: 1.05rem;
    line-height: 1.8;
    opacity: 0.85;
    margin-bottom: 2rem;
  }

  .hero .btn-primary {
    background: #fff;
    color: var(--accent);
  }

  .cover-img {
    border-radius: 4px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }

  /* TIMELINE */
  .timeline { background: var(--bg); padding: 5rem 1.5rem; }
  .timeline h2 { color: var(--accent); text-align: center; margin-bottom: 4rem; }

  .timeline-line {
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    padding-left: 100px;
  }

  .timeline-line::before {
    content: '';
    position: absolute;
    left: 80px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--border);
  }

  .timeline-entry {
    position: relative;
    margin-bottom: 4rem;
    padding-left: 2rem;
  }

  .timeline-entry::before {
    content: '';
    position: absolute;
    left: -22px;
    top: 8px;
    width: 12px;
    height: 12px;
    background: var(--accent);
    border-radius: 50%;
    border: 3px solid var(--bg);
  }

  .timeline-entry.war::before {
    background: var(--war);
  }

  .tl-year {
    position: absolute;
    left: -130px;
    top: 0;
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--accent);
    width: 90px;
    text-align: right;
  }

  .timeline-entry.war .tl-year {
    color: var(--war);
  }

  .tl-context {
    font-size: 0.85rem;
    color: var(--text-light);
    font-style: italic;
    margin-bottom: 0.8rem;
    padding: 0.5rem 0.8rem;
    background: var(--bg-alt);
    border-radius: 4px;
    border-left: 3px solid var(--border);
  }

  .timeline-entry.war .tl-context {
    border-left-color: var(--war);
    background: #FEF2F2;
  }

  .tl-story h3 {
    font-size: 1.3rem;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .timeline-entry.war .tl-story h3 {
    color: var(--war);
  }

  .tl-story p {
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .tl-photo {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .tl-photo img {
    border-radius: 4px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.1);
  }

  /* EXCERPT */
  .excerpt {
    background: var(--bg-alt);
    text-align: center;
    padding: 5rem 1.5rem;
  }

  .big-quote {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    border: none;
    padding: 0;
    color: var(--accent);
    margin-bottom: 2rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .excerpt-text {
    max-width: 650px;
    margin: 0 auto;
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text);
  }

  /* TESTIMONIALS */
  .testimonials { text-align: center; }
  .testimonials h2 { color: var(--accent); margin-bottom: 3rem; }

  .testi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .testi-card {
    background: var(--bg-alt);
    padding: 1.5rem;
    border-radius: 8px;
    text-align: left;
    border: 1px solid var(--border);
  }

  .testi-card p {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1rem;
    margin-bottom: 0.8rem;
    line-height: 1.5;
  }

  .testi-card cite {
    font-size: 0.8rem;
    color: var(--text-light);
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* AUTHOR */
  .author { background: var(--bg-alt); }

  .author-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3rem;
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .author-img {
    border-radius: 4px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.1);
  }

  .author h2 { color: var(--accent); margin-bottom: 1.5rem; }

  .author-parallel {
    margin-bottom: 1.5rem;
  }

  .parallel-item {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    margin-bottom: 0.5rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
  }

  .parallel-year {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.2rem;
    color: var(--accent);
    flex-shrink: 0;
    width: 50px;
  }

  .author-text p { margin-bottom: 1rem; }

  /* PRODUCT */
  .product { background: var(--bg); text-align: center; }
  .product h2 { color: var(--accent); margin-bottom: 0.5rem; }
  .product-sub { color: var(--text-light); margin-bottom: 3rem; }

  .product-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    max-width: 600px;
    margin: 0 auto;
  }

  .product-card {
    background: var(--bg-alt);
    padding: 2.5rem 2rem;
    border-radius: 8px;
    border: 2px solid var(--border);
    transition: border-color 0.3s;
  }

  .product-card:hover { border-color: var(--accent); }
  .product-icon { font-size: 2.5rem; margin-bottom: 1rem; }
  .product-card h3 { color: var(--accent); margin-bottom: 0.5rem; }
  .product-details { font-size: 0.9rem; color: var(--text-light); margin-bottom: 1rem; }
  .product-price { font-family: var(--font-heading); font-size: 2.5rem; font-weight: 700; color: var(--accent); margin-bottom: 0.3rem; }
  .product-shipping { font-size: 0.85rem; color: var(--text-light); margin-bottom: 1.5rem; }

  /* FOOTER */
  .footer { background: var(--accent); color: var(--bg); text-align: center; padding: 2.5rem 1.5rem; }
  .footer a { color: #D1D5DB; }
  .copyright { margin-top: 1rem; font-size: 0.8rem; opacity: 0.6; }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .nav-links a:not(.nav-cta) { display: none; }

    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .hero-image {
      order: -1;
    }

    .cover-img {
      max-width: 250px;
      margin: 0 auto;
    }

    .timeline-line {
      padding-left: 40px;
    }

    .timeline-line::before {
      left: 20px;
    }

    .timeline-entry::before {
      left: -22px;
    }

    .tl-year {
      position: static;
      width: auto;
      text-align: left;
      margin-bottom: 0.3rem;
    }

    .tl-photo {
      flex-direction: column;
    }

    .testi-grid {
      grid-template-columns: 1fr;
    }

    .author-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
  }
</style>
</BaseLayout>
